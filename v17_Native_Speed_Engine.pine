// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ICT US OPEN SWING ENGINE — PRODUCTION HUB V15 (SERVER RUNTIME SECURED)   ║
// ║  Production Live Engine — Zero-Load Live State Barriers For Clean Alerts  ║
// ╚══════════════════════════════════════════════════════════════════════════╝


//@version=5
indicator(
     title      = "ICT US Open Swing Production Engine v15",
     shorttitle = "ICT TP SL LEVELS",
     overlay    = true)


// ══════════════════════════════════════════════════════════════════════════════
// 🔒 COMPILER MEMORY MANAGEMENT
// ══════════════════════════════════════════════════════════════════════════════
max_bars_back(time, 1000)
max_bars_back(high, 1000)
max_bars_back(low, 1000)
max_bars_back(close, 1000)
max_bars_back(volume, 1000)


// ══════════════════════════════════════════════════════════════════════════════
// INPUT MATRIX CONFIGURATION
// ══════════════════════════════════════════════════════════════════════════════


var g_time    = "⏰ US Morning Killzone Clock (CST Mirror)"
killzoneTime  = input.session("0830-1030", "US Open Killzone Window (CST Base)", group=g_time)


var g_tf      = "⚙️ Timeframe Nesting Settings"
htfFilter     = input.timeframe("5",  "Layer 1 — Structural Narrative (HTF)", group=g_tf)
bosLookback   = input.int(8,   "BOS Lookback Memory (Lowered for speed)", minval=1, maxval=50, group=g_tf)


var g_swing   = "① Swing / Liquidity Parameters"
swingLen      = input.int  (2,     "Swing Lookback (Lowered for Morning Open)", minval=1, maxval=10, group=g_swing)


var g_fvg     = "② Fair Value Gaps Clutter Controls"
minFvgPct     = input.float(0.0,   "Min FVG size (% of price)",       minval=0.0, step=0.01, group=g_fvg)
showFvgBoxes  = input.bool (true,  "Show Active Gaps on Chart",                              group=g_fvg)


var g_fp      = "③ Footprint & Delta Divergence Settings"
imbalRatio    = input.float(1.3,   "Imbalance Ratio Gate (Lowered for speed)",minval=1.1, step=0.1,  group=g_fp)
minAbsDelta   = input.float(0.0,   "Min Absolute Delta to Confirm",    minval=0.0,            group=g_fp)
maxDeltaRef   = input.float(1000.0,"Max Delta Reference (MNQ Base)",   minval=10.0,         group=g_fp)


var g_risk    = "④ EXPANSION WINDOW TUNING (30-100 PTS)"
minConf       = input.float(0.00,  "Min Confidence Gate",             minval=0.0, maxval=1.0, step=0.05, group=g_risk)
minTargetPts  = input.float(30.0,  "Minimum Target Window Distance",  minval=10.0, step=5.0, group=g_risk)
maxTargetPts  = input.float(100.0, "Maximum Target Window Distance",  minval=50.0, step=5.0, group=g_risk)
defaultTarget = input.float(65.0,  "Fallback Pure Expansion Points",   minval=20.0, step=5.0, group=g_risk)


// ══════════════════════════════════════════════════════════════════════════════
// HTF EXTREME MACRO SECURITY FETCH (WEEKLY & MONTHLY HORIZONS)
// ══════════════════════════════════════════════════════════════════════════════


weeklyHigh  = request.security(syminfo.tickerid, "W", high[1], barmerge.gaps_off, barmerge.lookahead_on)
weeklyLow   = request.security(syminfo.tickerid, "W", low[1],  barmerge.gaps_off, barmerge.lookahead_on)
monthlyHigh = request.security(syminfo.tickerid, "M", high[1], barmerge.gaps_off, barmerge.lookahead_on)
monthlyLow  = request.security(syminfo.tickerid, "M", low[1],  barmerge.gaps_off, barmerge.lookahead_on)


// ══════════════════════════════════════════════════════════════════════════════
// TIME GATING & INTRADAY ACTION TRACKING
// ══════════════════════════════════════════════════════════════════════════════
inKillzone = not na(time(timeframe.period, killzoneTime + ":23456", "America/Chicago"))


htfHigh  = request.security(syminfo.tickerid, htfFilter, high[1],  barmerge.gaps_off, barmerge.lookahead_on)
htfLow   = request.security(syminfo.tickerid, htfFilter, low[1],   barmerge.gaps_off, barmerge.lookahead_on)
htfClose = request.security(syminfo.tickerid, htfFilter, close[1], barmerge.gaps_off, barmerge.lookahead_on)


isNewDay = ta.change(time("D")) != 0
var float dailyOpenHigh = na
var float dailyOpenLow  = na


if isNewDay
    dailyOpenHigh := high
    dailyOpenLow  := low
else
    dailyOpenHigh := math.max(high, nz(dailyOpenHigh, high))
    dailyOpenLow  := math.min(low, nz(dailyOpenLow, low))


inAsiaSession = not na(time(timeframe.period, "0000-0600"))
var float asiaHigh = na
var float asiaLow  = na
if inAsiaSession and not inAsiaSession[1]
    asiaHigh := high
    asiaLow  := low
else if inAsiaSession
    asiaHigh := math.max(high, nz(asiaHigh, high))
    asiaLow  := math.min(low, nz(asiaLow, low))


// ══════════════════════════════════════════════════════════════════════════════
// ORDER FLOW FOOTPRINT PROXY ENGINE
// ══════════════════════════════════════════════════════════════════════════════
barRange     = high - low
buyVolProxy  = barRange > 0 ? volume * (close - low)  / barRange : volume / 2
sellVolProxy = barRange > 0 ? volume * (high - close) / barRange : volume / 2
delta        = buyVolProxy - sellVolProxy


prevRange    = high[1] - low[1]
prevSellVol  = prevRange > 0 ? volume[1] * (high[1] - close[1]) / prevRange : volume[1] / 2
prevBuyVol   = prevRange > 0 ? volume[1] * (close[1] - low[1])  / prevRange : volume[1] / 2


buyingImbalance  = buyVolProxy  / math.max(prevSellVol, 1) >= imbalRatio
sellingImbalance = sellVolProxy / math.max(prevBuyVol,  1) >= imbalRatio


priceLowerLow = low < low[1] and low[1] < low[2]
deltaHigherLow = delta > delta[1] and delta[1] < delta[2]
bullDeltaDiv = priceLowerLow and deltaHigherLow


priceHigherHigh = high > high[1] and high[1] > high[2]
deltaLowerHigh = delta < delta[1] and delta[1] > delta[2]
bearDeltaDiv = priceHigherHigh and deltaLowerHigh


// ══════════════════════════════════════════════════════════════════════════════
// STRUCTURE PIPELINE & INVERSION MATRIX
// ══════════════════════════════════════════════════════════════════════════════
mtfSwingHigh = request.security(syminfo.tickerid, htfFilter, ta.pivothigh(high, swingLen, swingLen)[1], barmerge.gaps_off, barmerge.lookahead_on)
mtfSwingLow  = request.security(syminfo.tickerid, htfFilter, ta.pivotlow (low,  swingLen, swingLen)[1], barmerge.gaps_off, barmerge.lookahead_on)


var float lastMtfHigh = na
var float lastMtfLow  = na
if not na(mtfSwingHigh)
    lastMtfHigh := mtfSwingHigh
if not na(mtfSwingLow)
    lastMtfLow  := mtfSwingLow


mtfBullishBOS = not na(lastMtfHigh) and htfClose > lastMtfHigh
mtfBearishBOS = not na(lastMtfLow)  and htfClose < lastMtfLow


bool mtfBOSBullishActive = ta.barssince(mtfBullishBOS) <= bosLookback
bool mtfBOSBearishActive = ta.barssince(mtfBearishBOS) <= bosLookback


var fvgTop   = array.new_float(0)
var fvgBot   = array.new_float(0)
var fvgBull  = array.new_bool (0)
var fvgState = array.new_int  (0)
var fvgBar   = array.new_int  (0)


isBullFvg  = low > high[2] and (low - high[2]) >= (close * minFvgPct)
isBearFvg  = low[2] > high and (low[2] - high) >= (close * minFvgPct)


if isBullFvg
    array.push(fvgTop,   low)
    array.push(fvgBot,   high[2])
    array.push(fvgBull,  true)
    array.push(fvgState, 0)
    array.push(fvgBar,   bar_index - 1)


if isBearFvg
    array.push(fvgTop,   low[2])
    array.push(fvgBot,   high)
    array.push(fvgBull,  false)
    array.push(fvgState, 0)
    array.push(fvgBar,   bar_index - 1)


openBullFvgCount = 0
openBearFvgCount = 0
n = array.size(fvgState)


if n > 0
    for i = 0 to n - 1
        if i < array.size(fvgState) and i < array.size(fvgTop) and i < array.size(fvgBot) and i < array.size(fvgBull)
            if array.get(fvgState, i) == 0
                top  = array.get(fvgTop,  i)
                bot  = array.get(fvgBot,  i)
                bull = array.get(fvgBull, i)
                mid  = (top + bot) / 2
                if bull
                    if close < bot      
                        array.set(fvgState, i, 2)
                    else if close <= mid
                        array.set(fvgState, i, 1)
                    else
                        openBullFvgCount += 1
                else
                    if close > top      
                        array.set(fvgState, i, 2)
                    else if close >= mid
                        array.set(fvgState, i, 1)
                    else
                        openBearFvgCount += 1


var bool ltfInversionLong = false
var bool ltfInversionShort = false
if n > 0
    for i = n - 1 to 0
        if i < array.size(fvgState) and i < array.size(fvgBull) and i < array.size(fvgTop) and i < array.size(fvgBot)
            if array.get(fvgState, i) == 2
                if not array.get(fvgBull, i) and close > array.get(fvgTop, i)
                    ltfInversionLong := true
                if array.get(fvgBull, i) and close < array.get(fvgBot, i)
                    ltfInversionShort := true


var box[] activeFvgBoxes = array.new_box(0)
if showFvgBoxes and barstate.islast
    if array.size(activeFvgBoxes) > 0
        for i = 0 to array.size(activeFvgBoxes) - 1
            box.delete(array.get(activeFvgBoxes, i))
    array.clear(activeFvgBoxes)


    visualDrawn = 0
    totalGaps = array.size(fvgState)
    if totalGaps > 0
        for i = totalGaps - 1 to 0
            if i < array.size(fvgState) and i < array.size(fvgBull) and i < array.size(fvgBar) and i < array.size(fvgTop) and i < array.size(fvgBot)
                state  = array.get(fvgState, i)
                isBull = array.get(fvgBull,  i)
                if state == 0 and visualDrawn < 3
                    fvgBox = box.new(left=array.get(fvgBar, i), top=array.get(fvgTop, i), right=bar_index, bottom=array.get(fvgBot, i),
                         bgcolor=isBull ? color.new(color.lime, 93) : color.new(color.red, 93),
                         border_color=isBull ? color.new(color.lime, 60) : color.new(color.red, 60), border_width=0)
                    array.push(activeFvgBoxes, fvgBox)
                    visualDrawn += 1


// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY LOGIC CHECKLIST — FORCED BOOLEAN STABILITY
// ══════════════════════════════════════════════════════════════════════════════
longCondition  = inKillzone and mtfBOSBullishActive and (ltfInversionLong or openBullFvgCount > 0) and nz(buyingImbalance, false) and nz(delta, 0) > minAbsDelta and nz(bullDeltaDiv, false)
shortCondition = inKillzone and mtfBOSBearishActive and (ltfInversionShort or openBearFvgCount > 0) and nz(sellingImbalance, false) and nz(delta, 0) < -minAbsDelta and nz(bearDeltaDiv, false)


// ══════════════════════════════════════════════════════════════════════════════
// POSITION ENGINE STATE CONTROLLER
// ══════════════════════════════════════════════════════════════════════════════
var int   tradeState = 0  
var float currentSL  = na
var float currentTP  = na


if tradeState == 1
    if low <= currentSL or high >= currentTP
        tradeState := 0
        currentSL  := na
        currentTP  := na
else if tradeState == -1
    if high >= currentSL or low <= currentTP
        tradeState := 0
        currentSL  := na
        currentTP  := na


executeLong  = longCondition and tradeState == 0
executeShort = shortCondition and tradeState == 0


safeAsiaHigh   = nz(asiaHigh, close)
safeAsiaLow    = nz(asiaLow, close)
safeDailyHigh  = nz(dailyOpenHigh, close)
safeDailyLow   = nz(dailyOpenLow, close)
safeWeeklyHigh = nz(weeklyHigh, close)
safeWeeklyLow  = nz(weeklyLow, close)
safeMonthlyHigh = nz(monthlyHigh, close)
safeMonthlyLow  = nz(monthlyLow, close)


longTPPrice = executeLong ? (
     (safeAsiaHigh > close and (safeAsiaHigh - close) >= minTargetPts and (safeAsiaHigh - close) <= maxTargetPts) ? safeAsiaHigh :
     (safeDailyHigh > close and (safeDailyHigh - close) >= minTargetPts and (safeDailyHigh - close) <= maxTargetPts) ? safeDailyHigh :
     (safeWeeklyHigh > close and (safeWeeklyHigh - close) >= minTargetPts and (safeWeeklyHigh - close) <= maxTargetPts) ? safeWeeklyHigh :
     (safeMonthlyHigh > close and (safeMonthlyHigh - close) >= minTargetPts and (safeMonthlyHigh - close) <= maxTargetPts) ? safeMonthlyHigh :
     close + defaultTarget) : na


shortTPPrice = executeShort ? (
     (safeAsiaLow < close and (close - safeAsiaLow) >= minTargetPts and (close - safeAsiaLow) <= maxTargetPts) ? safeAsiaLow :
     (safeDailyLow < close and (close - safeDailyLow) >= minTargetPts and (close - safeDailyLow) <= maxTargetPts) ? safeDailyLow :
     (safeWeeklyLow < close and (close - safeWeeklyLow) >= minTargetPts and (close - safeWeeklyLow) <= maxTargetPts) ? safeWeeklyLow :
     (safeMonthlyLow < close and (close - safeMonthlyLow) >= minTargetPts and (close - safeMonthlyLow) <= maxTargetPts) ? safeMonthlyLow :
     close - defaultTarget) : na


rawLongSL   = not na(lastMtfLow) ? lastMtfLow : low
longSLPrice = executeLong ? math.max(rawLongSL, close - (longTPPrice - close)) : na


rawShortSL   = not na(lastMtfHigh) ? lastMtfHigh : high
shortSLPrice = executeShort ? math.min(rawShortSL, close + (close - shortTPPrice)) : na


if executeLong
    tradeState := 1
    currentSL  := longSLPrice
    currentTP  := longTPPrice


if executeShort
    tradeState := -1
    currentSL  := shortSLPrice
    currentTP  := shortTPPrice


if not inKillzone and tradeState != 0
    tradeState := 0
    currentSL  := na
    currentTP  := na


// Continuous Visual Target Plots
plot(tradeState != 0 ? currentSL : na, title="⚠️ BALANCED STOP LOSS", color=color.red, style=plot.style_linebr, linewidth=3)
plot(tradeState != 0 ? currentTP : na, title="🎯 WIDE LIQUIDITY TARGET", color=color.lime, style=plot.style_linebr, linewidth=3)


// Shapes Rendering
plotshape(executeLong,  title="BUY ARROW",  style=shape.triangleup,   location=location.belowbar, color=color.lime, size=size.normal)
plotshape(executeShort, title="SELL ARROW", style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.normal)


if executeLong
    label.new(bar_index, low, text="🚀 EXPANSION LONG\nTP (Key Horizon): " + str.tostring(longTPPrice, format.mintick) + "\nSL (Breathing Room): " + str.tostring(longSLPrice, format.mintick), style=label.style_label_up, color=color.lime, textcolor=color.black, size=size.small)
if executeShort
    label.new(bar_index, high, text="📉 EXPANSION SHORT\nTP (Key Horizon): " + str.tostring(shortTPPrice, format.mintick) + "\nSL (Breathing Room): " + str.tostring(shortSLPrice, format.mintick), style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)


// ══════════════════════════════════════════════════════════════════════════════
// ⚡ FIX: ABSOLUTE BARSTATE ISLAST SHIELDED DISCORD DISPATCHER
// ══════════════════════════════════════════════════════════════════════════════
// This guarantees that the background alert executor only triggers on real-time price action bars, completely avoiding past loop calculation drops.
f_discordJson(action, entryPrice, sl, tp, points) =>
    jsonTemplate = '"content":"🚨 **ICT STALWART SWING SETUP** 🚨\\n\\n**Action:** {0}\\n**Symbol:** {1}\\n**Entry Price:** {2}\\n**Breathing SL:** {3}\\n**Macro Target:** {4}\\n**Target Size:** {5} Points"'
    "{" + str.format(jsonTemplate, action, syminfo.ticker, str.tostring(entryPrice, "#.##"), str.tostring(sl, "#.##"), str.tostring(tp, "#.##"), str.tostring(points, "#")) + "}"


if barstate.islast
    if executeLong
        alert(f_discordJson("⚡ GO LONG", close, longSLPrice, longTPPrice, (longTPPrice - close)), alert.freq_once_per_bar_close)
    if executeShort
        alert(f_discordJson("🔻 GO SHORT", close, shortSLPrice, shortTPPrice, (close - shortTPPrice)), alert.freq_once_per_bar_close)
