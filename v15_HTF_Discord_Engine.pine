// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ICT US OPEN SWING ENGINE — PRODUCTION HUB V17 (SYNTAX FIXED)            ║
// ║  Production Live Engine — High-Speed Native Timeframe Execution Hub      ║
// ╚══════════════════════════════════════════════════════════════════════════╝


//@version=5
indicator(
     title      = "ICT US Open Swing Production Engine v17",
     shorttitle = "ICT ARROWS",
     overlay    = true)


// ══════════════════════════════════════════════════════════════════════════════
// INPUT MATRIX CONFIGURATION
// ══════════════════════════════════════════════════════════════════════════════
var g_time    = "⏰ US Morning Killzone Clock (CST Mirror)"
killzoneTime  = input.session("0830-1030", "US Open Killzone Window (CST Base)", group=g_time)


var g_swing   = "① Swing / Liquidity Parameters"
swingLen      = input.int(2, "Swing Lookback Memory", minval=1, maxval=10, group=g_swing)


var g_fp      = "② Footprint & Delta Divergence Settings"
imbalRatio    = input.float(1.3,   "Imbalance Ratio Gate", minval=1.1, step=0.1,  group=g_fp)
minAbsDelta   = input.float(0.0,   "Min Absolute Delta",   minval=0.0,            group=g_fp)


var g_risk    = "③ TARGET CODES"
defaultTarget = input.float(65.0,  "Fixed Expansion Points Target", minval=10.0, step=5.0, group=g_risk)


// ══════════════════════════════════════════════════════════════════════════════
// NATIVE TIME GATING & PRICE ACTION PIPELINES
// ══════════════════════════════════════════════════════════════════════════════
inKillzone = not na(time(timeframe.period, killzoneTime + ":23456", "America/Chicago"))


// Order Flow Footprint Proxy
barRange     = high - low
buyVolProxy  = barRange > 0 ? volume * (close - low)  / barRange : volume / 2
sellVolProxy = barRange > 0 ? volume * (high - close) / barRange : volume / 2
delta        = buyVolProxy - sellVolProxy


prevRange    = high[1] - low[1]
prevSellVol  = prevRange > 0 ? volume[1] * (high[1] - close[1]) / prevRange : volume[1] / 2
prevBuyVol   = prevRange > 0 ? volume[1] * (close[1] - low[1])  / prevRange : volume[1] / 2


buyingImbalance  = buyVolProxy  / math.max(prevSellVol, 1) >= imbalRatio
sellingImbalance = sellVolProxy / math.max(prevBuyVol,  1) >= imbalRatio


// Native Delta Divergences
priceLowerLow  = low < low[1] and low[1] < low[2]
deltaHigherLow = delta > delta[1] and delta[1] < delta[2]
bullDeltaDiv   = priceLowerLow and deltaHigherLow


priceHigherHigh = high > high[1] and high[1] > high[2]
deltaLowerHigh  = delta < delta[1] and delta[1] > delta[2]
bearDeltaDiv    = priceHigherHigh and deltaLowerHigh


// Local Structural Tracking
localSwingHigh = ta.pivothigh(high, swingLen, swingLen)
localSwingLow  = ta.pivotlow(low,   swingLen, swingLen)


var float lastLocalHigh = na
var float lastLocalLow  = na
if not na(localSwingHigh)
    lastLocalHigh := high[swingLen]
if not na(localSwingLow)
    lastLocalLow  := low[swingLen]


// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY LOGIC CHECKLIST (ZERO HTF CALLS FOR 100% UPTIME STABILITY)
// ══════════════════════════════════════════════════════════════════════════════
longCondition  = inKillzone and nz(buyingImbalance, false) and nz(delta, 0) > minAbsDelta and nz(bullDeltaDiv, false)
shortCondition = inKillzone and nz(sellingImbalance, false) and nz(delta, 0) < -minAbsDelta and nz(bearDeltaDiv, false)


// ══════════════════════════════════════════════════════════════════════════════
// RISK SPACE CAP MATRICES
// ══════════════════════════════════════════════════════════════════════════════
var int   tradeState = 0  
var float currentSL  = na
var float currentTP  = na


if tradeState == 1
    if low <= currentSL or high >= currentTP
        tradeState := 0
        currentSL  := na
        currentTP  := na
else if tradeState == -1
    if high >= currentSL or low <= currentTP
        tradeState := 0
        currentSL  := na
        currentTP  := na


executeLong  = longCondition and tradeState == 0
executeShort = shortCondition and tradeState == 0


longTPPrice  = executeLong ? close + defaultTarget : na
shortTPPrice = executeShort ? close - defaultTarget : na


rawLongSL   = not na(lastLocalLow) ? lastLocalLow : low
longSLPrice = executeLong ? math.max(rawLongSL, close - defaultTarget) : na


rawShortSL   = not na(lastLocalHigh) ? lastLocalHigh : high
shortSLPrice = executeShort ? math.min(rawShortSL, close + defaultTarget) : na


if executeLong
    tradeState := 1
    currentSL  := longSLPrice
    currentTP  := longTPPrice
if executeShort
    tradeState := -1
    currentSL  := shortSLPrice
    currentTP  := shortTPPrice
if not inKillzone and tradeState != 0
    tradeState := 0
    currentSL  := na
    currentTP  := na


// Elements Rendering
plotshape(executeLong,  title="BUY",  style=shape.triangleup,   location=location.belowbar, color=color.lime, size=size.normal)
plotshape(executeShort, title="SELL", style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.normal)


// Native, Clean Cloud Alerts
if barstate.islast
    if executeLong
        alert('{"content":"🚀 NATIVE LONG ENTRY AT ' + str.tostring(close) + '"}', alert.freq_once_per_bar_close)
    if executeShort
        alert('{"content":"🔻 NATIVE SHORT ENTRY AT ' + str.tostring(close) + '"}', alert.freq_once_per_bar_close)
